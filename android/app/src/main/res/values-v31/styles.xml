<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ splash screen: brand orange field with the Nmimes eyes,
         handing off seamlessly to the Flutter splash which continues the
         blink animation on the same background. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_eyes_icon</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/app_background</item>
    </style>
</resources>
