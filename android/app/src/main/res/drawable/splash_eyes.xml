<?xml version="1.0" encoding="utf-8"?>
<!-- The Nmimes eyes: two overlapping cream circles with dark pupils.
     Mirrors EyesPainter in lib/screens/splash/splash_screen.dart so the
     native launch screen hands off seamlessly to the Flutter splash. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Cream eye blobs: centers at (37.6, 54) and (70.4, 54), radius 32.4.
         Circles drawn as two arcs each. -->
    <path
        android:fillColor="#FCE9C8"
        android:pathData="M37.6,21.6 A32.4,32.4 0 1,1 37.6,86.4 A32.4,32.4 0 1,1 37.6,21.6 Z" />
    <path
        android:fillColor="#FCE9C8"
        android:pathData="M70.4,21.6 A32.4,32.4 0 1,1 70.4,86.4 A32.4,32.4 0 1,1 70.4,21.6 Z" />

    <!-- Pupils: radius 18.8 (0.58 of the eye radius). -->
    <path
        android:fillColor="#141414"
        android:pathData="M37.6,35.2 A18.8,18.8 0 1,1 37.6,72.8 A18.8,18.8 0 1,1 37.6,35.2 Z" />
    <path
        android:fillColor="#141414"
        android:pathData="M70.4,35.2 A18.8,18.8 0 1,1 70.4,72.8 A18.8,18.8 0 1,1 70.4,35.2 Z" />
</vector>
