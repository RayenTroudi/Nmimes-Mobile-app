<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ splash icon variant of splash_eyes. The system masks the
     icon to a circle and only ~2/3 of the 108dp canvas is safely visible,
     so the eyes are scaled down into that inner safe zone. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="0.62"
        android:scaleY="0.62">

        <!-- Cream eye blobs -->
        <path
            android:fillColor="#FCE9C8"
            android:pathData="M37.6,21.6 A32.4,32.4 0 1,1 37.6,86.4 A32.4,32.4 0 1,1 37.6,21.6 Z" />
        <path
            android:fillColor="#FCE9C8"
            android:pathData="M70.4,21.6 A32.4,32.4 0 1,1 70.4,86.4 A32.4,32.4 0 1,1 70.4,21.6 Z" />

        <!-- Pupils -->
        <path
            android:fillColor="#141414"
            android:pathData="M37.6,35.2 A18.8,18.8 0 1,1 37.6,72.8 A18.8,18.8 0 1,1 37.6,35.2 Z" />
        <path
            android:fillColor="#141414"
            android:pathData="M70.4,35.2 A18.8,18.8 0 1,1 70.4,72.8 A18.8,18.8 0 1,1 70.4,35.2 Z" />
    </group>
</vector>
