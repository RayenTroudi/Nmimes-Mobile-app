<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ in dark mode. Without this, values-night would win over
         values-v31 (mode qualifiers outrank version qualifiers) and dark-mode
         users would miss the splash icon. Kept identical to values-v31 so the
         brand moment is the same in both modes. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_eyes_icon</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/app_background</item>
    </style>
</resources>
