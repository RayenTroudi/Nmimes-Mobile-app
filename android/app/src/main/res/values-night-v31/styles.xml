<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ in dark mode. Without this, values-night would win over
         values-v31 (mode qualifiers outrank version qualifiers) and dark-mode
         users would get a different launch. Kept identical to values-v31: a
         plain orange field with no icon, so the OS splash is just the
         background and the Flutter splash draws the eyes. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <!-- Transparent icon so the OS does not fall back to the app launcher
             icon; the splash frame stays a plain orange field. -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/app_background</item>
    </style>
</resources>
